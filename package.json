    "build:assets": "node scripts/build-assets.js",
    "test": "node --test"
  },
  "dependencies": {
    "@dr.pogodin/csurf": "^1.16.8",
    "@prisma/client": "6.2.0",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-ejs-layouts": "^2.5.1",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "6.2.0",
