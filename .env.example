DATABASE_URL="mysql://helpdesk_user:troque_esta_senha@localhost:3306/helpdesk"
NODE_ENV=development
PORT=3001

# Use 32+ caracteres em produção.
SESSION_SECRET="troque_esta_chave_secreta_em_producao"
SESSION_MAX_AGE_MS=28800000
SESSION_STORE=mysql
SESSION_COOKIE_NAME=helpdesk.sid
SESSION_SAME_SITE=lax
COOKIE_SECURE=false
TRUST_PROXY=false
TRUST_PROXY_HOPS=1

UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=8388608
UPLOAD_MAX_FILES=5
SYSTEM_ASSET_DIR=uploads/system
REPORT_LOGO_MAX_BYTES=2097152
REPORT_MAX_ROWS=5000
PDF_MAX_ROWS=250

RATE_LIMIT_GENERAL=600
RATE_LIMIT_LOGIN=10
RATE_LIMIT_WRITE=120
RATE_LIMIT_UPLOAD=30
LOG_LEVEL=info
LOG_DIR=logs
LOG_FILE=system.log
LOG_TO_STDOUT=true
ASSET_VARIANT=modern
CIRCUIT_BREAKER_FAILURES=5
CIRCUIT_BREAKER_RESET_MS=30000
CIRCUIT_BREAKER_TIMEOUT_MS=10000
SMTP_TIMEOUT_MS=15000
SMTP_CIRCUIT_RESET_MS=60000
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000
HTTP_HEADERS_TIMEOUT_MS=66000
HTTP_REQUEST_TIMEOUT_MS=120000
SHUTDOWN_TIMEOUT_MS=10000

BCRYPT_COST=12
PUBLIC_BASE_URL="http://localhost:3001"
PASSWORD_RESET_TTL_MINUTES=30
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SEED_ADMIN_LOGIN=Admin
SEED_ADMIN_PASSWORD="senha-provisoria-para-trocar-em-producao" # Troque esta senha em produção
AUTO_COORDINATOR_FOR_ENFERMEIRO=true
