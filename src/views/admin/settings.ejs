<%
  const settings = reportSettings || {};
%>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h3 mb-1 text-gray-800">
      <i class="bi bi-gear text-primary"></i> Configurações do Sistema
    </h1>
    <p class="text-muted mb-0">Padrões operacionais, aparência de relatórios e informações da instalação.</p>
  </div>
</div>

<div class="row g-3">
  <div class="col-xl-8">
    <div class="card shadow mb-4">
      <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">
          <i class="bi bi-file-earmark-bar-graph"></i> Relatórios PDF/XLSX
        </h6>
      </div>
      <div class="card-body">
        <form method="post" action="/admin/settings/reports?_csrf=<%= csrfToken %>" enctype="multipart/form-data">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Nome do órgão <span class="text-danger">*</span></label>
              <input class="form-control" name="organizationName" maxlength="140" required
                     value="<%= settings.organizationName || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Prefixo do título <span class="text-danger">*</span></label>
              <input class="form-control" name="reportTitlePrefix" maxlength="140" required
                     value="<%= settings.reportTitlePrefix || '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">Layout padrão</label>
              <select class="form-select" name="layout">
                <option value="classic" <%= settings.layout === 'classic' ? 'selected' : '' %>>Clássico</option>
                <option value="compact" <%= settings.layout === 'compact' ? 'selected' : '' %>>Compacto</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Papel</label>
              <select class="form-select" name="paperSize">
                <option value="A4" <%= settings.paperSize === 'A4' ? 'selected' : '' %>>A4</option>
                <option value="LETTER" <%= settings.paperSize === 'LETTER' ? 'selected' : '' %>>Carta</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Orientação</label>
              <select class="form-select" name="orientation">
                <option value="landscape" <%= settings.orientation === 'landscape' ? 'selected' : '' %>>Paisagem</option>
                <option value="portrait" <%= settings.orientation === 'portrait' ? 'selected' : '' %>>Retrato</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Cor de destaque</label>
              <input class="form-control form-control-color w-100" type="color" name="accentColor"
                     value="<%= settings.accentColor || '#0d6efd' %>">
            </div>
            <div class="col-md-8">
              <label class="form-label">Rodapé do relatório</label>
              <input class="form-control" name="footerText" maxlength="180"
                     value="<%= settings.footerText || '' %>">
            </div>
            <div class="col-md-8">
              <label class="form-label">Logo da prefeitura <span class="text-muted">(PNG, JPG ou WebP até 2 MB)</span></label>
              <input class="form-control" type="file" name="logo" accept=".png,.jpg,.jpeg,.webp">
              <% if (settings.logoFile) { %>
                <div class="form-check mt-2">
                  <input class="form-check-input" type="checkbox" id="removeLogo" name="removeLogo">
                  <label class="form-check-label" for="removeLogo">Remover logo atual</label>
                </div>
              <% } %>
            </div>
            <div class="col-md-4">
              <% if (settings.logoFile) { %>
                <div class="border rounded p-2 bg-light text-center">
                  <img src="/system-assets/<%= settings.logoFile %>" alt="Logo atual" class="img-fluid report-logo-preview">
                </div>
              <% } else { %>
                <div class="border rounded p-3 bg-light text-center text-muted small">
                  Nenhuma logo cadastrada.
                </div>
              <% } %>
            </div>
          </div>

          <div class="d-flex flex-wrap gap-3 mt-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="includeLogo" name="includeLogo"
                     <%= settings.includeLogo ? 'checked' : '' %>>
              <label class="form-check-label" for="includeLogo">Exibir logo por padrão</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="includeGeneratedBy" name="includeGeneratedBy"
                     <%= settings.includeGeneratedBy ? 'checked' : '' %>>
              <label class="form-check-label" for="includeGeneratedBy">Exibir usuário gerador</label>
            </div>
          </div>

          <div class="d-flex justify-content-end mt-4">
            <button class="btn btn-primary" type="submit">
              <i class="bi bi-save"></i> Salvar configurações
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-xl-4">
    <div class="card shadow mb-4">
      <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">
          <i class="bi bi-sliders"></i> Preferências operacionais
        </h6>
      </div>
      <div class="card-body">
        <div class="mb-3">
          <div class="small text-muted mb-1">Coordenador automático para enfermeiros</div>
          <% if (autoCoordinator) { %>
            <span class="badge bg-success">Ativo</span>
          <% } else { %>
            <span class="badge bg-warning text-dark">Inativo</span>
          <% } %>
        </div>
        <div class="mb-3">
          <div class="small text-muted mb-1">Acesso</div>
          <div class="fw-semibold">Sessões e permissões são tratadas automaticamente.</div>
        </div>
        <div class="mb-0">
          <div class="small text-muted mb-1">Conta</div>
          <div class="fw-semibold">Usuários podem redefinir e alterar a própria senha.</div>
        </div>
      </div>
    </div>

    <div class="card shadow">
      <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">
          <i class="bi bi-lightning"></i> Ações rápidas
        </h6>
      </div>
      <div class="card-body d-grid gap-2">
        <a href="/reports" class="btn btn-outline-primary">
          <i class="bi bi-bar-chart"></i> Abrir relatórios
        </a>
        <a href="/admin/users" class="btn btn-outline-primary">
          <i class="bi bi-people"></i> Gerenciar usuários
        </a>
        <a href="/admin/audit" class="btn btn-outline-primary">
          <i class="bi bi-journal-text"></i> Ver auditoria
        </a>
      </div>
    </div>
  </div>
</div>
