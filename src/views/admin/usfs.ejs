<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
  <div>
    <h1 class="h3 mb-1">
      <i class="bi bi-building text-primary"></i> Unidades de saúde
    </h1>
    <p class="text-muted mb-0">Cadastre e mantenha os dados operacionais de cada unidade.</p>
  </div>
</div>

<div class="card shadow mb-4">
  <div class="card-header py-3">
    <h6 class="m-0 font-weight-bold text-primary">
      <i class="bi bi-plus-circle"></i> Nova unidade
    </h6>
  </div>
  <div class="card-body">
    <form method="post" action="/admin/usfs">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="row g-3">
        <div class="col-lg-5">
          <label for="usfName" class="form-label">Nome da unidade <span class="required-mark">Obrigatório</span></label>
          <input type="text" class="form-control" id="usfName" name="nome" required maxlength="120" placeholder="Ex: USF Central">
        </div>
        <div class="col-md-4 col-lg-3">
          <label class="form-label">IP da ONT <span class="optional-mark">Opcional</span></label>
          <input type="text" class="form-control" name="ipOnt" maxlength="80" placeholder="Ex: 192.168.1.1">
        </div>
        <div class="col-md-4 col-lg-2">
          <label class="form-label">Switch <span class="optional-mark">Opcional</span></label>
          <input type="text" class="form-control" name="modeloSwitch" maxlength="120" placeholder="Modelo">
        </div>
        <div class="col-md-4 col-lg-2">
          <label class="form-label">Provedor <span class="optional-mark">Opcional</span></label>
          <input type="text" class="form-control" name="provedorInternet" maxlength="120" placeholder="Internet">
        </div>
      </div>
      <div class="d-flex justify-content-end mt-3">
        <button class="btn btn-primary" type="submit">
          <i class="bi bi-check-circle"></i> Cadastrar
        </button>
      </div>
    </form>
  </div>
</div>

<div class="card shadow">
  <div class="card-header py-3">
    <h6 class="m-0 font-weight-bold text-primary">
      <i class="bi bi-list-ul"></i> Unidades cadastradas
      <span class="badge bg-primary ms-2"><%= usfs.length %></span>
    </h6>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4" width="80">ID</th>
            <th>Unidade</th>
            <th>Rede</th>
            <th class="text-end pe-4">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (usfs.length === 0) { %>
            <tr>
              <td colspan="4" class="text-center py-5 text-muted">
                <i class="bi bi-building fs-1 d-block mb-2"></i>
                Nenhuma unidade cadastrada ainda.
              </td>
            </tr>
          <% } else { %>
            <% usfs.forEach(u => { %>
              <tr>
                <td class="ps-4"><span class="badge bg-light text-dark border">#<%= u.id %></span></td>
                <td>
                  <div class="d-flex align-items-center">
                    <div class="avatar-sm bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3">
                      <i class="bi bi-building text-primary"></i>
                    </div>
                    <div>
                      <div class="fw-semibold"><%= u.nome %></div>
                      <% if (u.provedorInternet) { %>
                        <small class="text-muted"><i class="bi bi-wifi"></i> <%= u.provedorInternet %></small>
                      <% } %>
                    </div>
                  </div>
                </td>
                <td>
                  <% if (u.ipOnt || u.modeloSwitch) { %>
                    <div class="small">
                      <% if (u.ipOnt) { %><div><i class="bi bi-router text-muted"></i> <%= u.ipOnt %></div><% } %>
                      <% if (u.modeloSwitch) { %><div><i class="bi bi-hdd-network text-muted"></i> <%= u.modeloSwitch %></div><% } %>
                    </div>
                  <% } else { %>
                    <span class="text-muted small">Sem dados de rede</span>
                  <% } %>
                </td>
                <td class="text-end pe-4">
                  <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#editUsf-<%= u.id %>" title="Editar">
                    <i class="bi bi-pencil-square"></i>
                  </button>
                  <form method="post" action="/admin/usfs/<%= u.id %>/delete" class="d-inline js-confirm-action"
                    data-confirm-title="Excluir unidade"
                    data-confirm-message="Excluir a unidade <%= u.nome %>? A operação só será concluída se não houver usuários, chamados, setores ou equipamentos vinculados."
                    data-confirm-confirm="Excluir unidade"
                    data-confirm-variant="btn-danger">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-sm btn-outline-danger ms-1" type="submit" title="Excluir">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<% usfs.forEach(u => { %>
  <div class="modal fade" id="editUsf-<%= u.id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <form method="post" action="/admin/usfs/<%= u.id %>/update" class="modal-content">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Editar unidade</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Nome da unidade <span class="required-mark">Obrigatório</span></label>
              <input class="form-control" name="nome" value="<%= u.nome %>" maxlength="120" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Provedor <span class="optional-mark">Opcional</span></label>
              <input class="form-control" name="provedorInternet" value="<%= u.provedorInternet || '' %>" maxlength="120">
            </div>
            <div class="col-md-6">
              <label class="form-label">IP da ONT <span class="optional-mark">Opcional</span></label>
              <input class="form-control" name="ipOnt" value="<%= u.ipOnt || '' %>" maxlength="80">
            </div>
            <div class="col-md-6">
              <label class="form-label">Modelo do switch <span class="optional-mark">Opcional</span></label>
              <input class="form-control" name="modeloSwitch" value="<%= u.modeloSwitch || '' %>" maxlength="120">
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar alterações</button>
        </div>
      </form>
    </div>
  </div>
<% }) %>
