<%
  const tipoLabels = { TONER: 'Toner', CABO: 'Cabo', PECAS: 'Peças e periféricos' };
%>

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
  <div>
    <h1 class="h3 mb-1">
      <i class="bi bi-box-seam text-primary"></i> Estoque de insumos
    </h1>
    <p class="text-muted mb-0">Controle materiais usados em chamados e alertas de quantidade mínima.</p>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-4">
    <div class="card shadow mb-4">
      <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Novo item</h6>
      </div>
      <div class="card-body">
        <form method="post" action="/admin/insumos">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label class="form-label">Nome do item <span class="required-mark">Obrigatório</span></label>
            <input type="text" name="nome" class="form-control" required maxlength="120" placeholder="Ex: Toner HP 85A">
          </div>
          <div class="mb-3">
            <label class="form-label">Tipo <span class="required-mark">Obrigatório</span></label>
            <select name="tipo" class="form-select">
              <option value="TONER">Toner</option>
              <option value="CABO">Cabo</option>
              <option value="PECAS">Peças e periféricos</option>
            </select>
          </div>
          <div class="row g-3">
            <div class="col-6">
              <label class="form-label">Qtd. inicial <span class="required-mark">Obrigatório</span></label>
              <input type="number" name="quantidadeAtual" class="form-control" value="0" min="0">
            </div>
            <div class="col-6">
              <label class="form-label">Mínimo <span class="required-mark">Obrigatório</span></label>
              <input type="number" name="quantidadeMinima" class="form-control" value="5" min="0">
            </div>
          </div>
          <button class="btn btn-primary w-100 mt-3" type="submit">Cadastrar item</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card shadow mb-4">
      <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">
          Inventário atual
          <span class="badge bg-primary ms-2"><%= insumos.length %></span>
        </h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead>
              <tr>
                <th class="ps-4">Nome</th>
                <th>Tipo</th>
                <th>Quantidade</th>
                <th>Mínimo</th>
                <th>Status</th>
                <th class="text-end pe-4">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if (insumos.length === 0) { %>
                <tr>
                  <td colspan="6" class="text-center py-5 text-muted">Estoque vazio.</td>
                </tr>
              <% } else { %>
                <% insumos.forEach(item => { %>
                  <tr>
                    <td class="ps-4 fw-semibold"><%= item.nome %></td>
                    <td><span class="badge text-bg-light border"><%= tipoLabels[item.tipo] || item.tipo %></span></td>
                    <td class="fw-bold"><%= item.quantidadeAtual %></td>
                    <td><%= item.quantidadeMinima %></td>
                    <td>
                      <% if (item.quantidadeAtual < item.quantidadeMinima) { %>
                        <span class="badge bg-danger">Baixo</span>
                      <% } else { %>
                        <span class="badge bg-success">OK</span>
                      <% } %>
                    </td>
                    <td class="text-end pe-4">
                      <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#modalStock-<%= item.id %>" title="Ajustar estoque">
                        <i class="bi bi-plus-slash-minus"></i>
                      </button>
                      <button class="btn btn-sm btn-outline-secondary ms-1" type="button" data-bs-toggle="modal" data-bs-target="#modalEditInsumo-<%= item.id %>" title="Editar cadastro">
                        <i class="bi bi-pencil-square"></i>
                      </button>
                      <form method="post" action="/admin/insumos/<%= item.id %>/delete" class="d-inline js-confirm-action"
                        data-confirm-title="Excluir insumo"
                        data-confirm-message="Excluir o insumo <%= item.nome %>? A operação só será concluída se ele não tiver histórico de uso em chamados."
                        data-confirm-confirm="Excluir insumo"
                        data-confirm-variant="btn-danger">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn-sm btn-outline-danger ms-1" type="submit" title="Excluir">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<% insumos.forEach(item => { %>
  <div class="modal fade" id="modalStock-<%= item.id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <form method="post" action="/admin/insumos/<%= item.id %>/update" class="modal-content">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-header">
          <h5 class="modal-title">Ajustar estoque: <%= item.nome %></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Ação <span class="required-mark">Obrigatório</span></label>
            <select name="action" class="form-select">
              <option value="add">Adicionar à quantidade atual</option>
              <option value="set">Definir quantidade exata</option>
            </select>
          </div>
          <div class="mb-0">
            <label class="form-label">Quantidade <span class="required-mark">Obrigatório</span></label>
            <input type="number" name="quantidade" class="form-control" required min="0">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar ajuste</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal fade" id="modalEditInsumo-<%= item.id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <form method="post" action="/admin/insumos/<%= item.id %>/edit" class="modal-content">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-header">
          <h5 class="modal-title">Editar insumo</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Nome do item <span class="required-mark">Obrigatório</span></label>
            <input class="form-control" name="nome" value="<%= item.nome %>" maxlength="120" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Tipo <span class="required-mark">Obrigatório</span></label>
            <select name="tipo" class="form-select">
              <% Object.keys(tipoLabels).forEach(tipo => { %>
                <option value="<%= tipo %>" <%= tipo === item.tipo ? 'selected' : '' %>><%= tipoLabels[tipo] %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="form-label">Quantidade mínima <span class="required-mark">Obrigatório</span></label>
            <input type="number" name="quantidadeMinima" class="form-control" value="<%= item.quantidadeMinima %>" min="0">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar alterações</button>
        </div>
      </form>
    </div>
  </div>
<% }) %>
