# Copie para .env.docker e use com:
# docker compose --env-file .env.docker up -d --build

APP_PORT=3000

MYSQL_ROOT_PASSWORD=troque_esta_senha_root
MYSQL_DATABASE=helpdesk
MYSQL_USER=helpdesk_user
# Use senha URL-safe porque ela compoe a DATABASE_URL do container.
MYSQL_PASSWORD=troque_esta_senha_do_banco

SESSION_SECRET=troque_esta_chave_com_32_ou_mais_caracteres
SESSION_MAX_AGE_MS=28800000
SESSION_STORE=mysql
SESSION_COOKIE_NAME=helpdesk.sid
SESSION_SAME_SITE=lax

# Em producao com HTTPS/proxy reverso, use COOKIE_SECURE=true e TRUST_PROXY=true.
# Para teste local sem HTTPS, use COOKIE_SECURE=false.
COOKIE_SECURE=false
TRUST_PROXY=false
TRUST_PROXY_HOPS=1
PUBLIC_BASE_URL=http://localhost:3000

UPLOAD_MAX_BYTES=8388608
UPLOAD_MAX_FILES=5
REPORT_LOGO_MAX_BYTES=2097152
REPORT_MAX_ROWS=5000
PDF_MAX_ROWS=250

LOG_LEVEL=info
LOG_FILE=system.log
LOG_TO_STDOUT=true
ASSET_VARIANT=modern

RUN_MIGRATIONS=true
RUN_SEED=false

SEED_ADMIN_LOGIN=Admin
SEED_ADMIN_PASSWORD=troque_esta_senha_inicial_do_admin
SEED_ADMIN_EMAIL=

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

AUTO_COORDINATOR_FOR_ENFERMEIRO=true
